#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
fi
# cmd-shim-target=/home/user/projects/mission-control/.pnpm-store/v11/links/@/pnpm/10.25.0/d01e2cf899e961bc61d9fed7f22d59ce9df09b5fea3f6aa2d17a114de4ef2ad6/node_modules/pnpm/bin/pnpm.cjs
